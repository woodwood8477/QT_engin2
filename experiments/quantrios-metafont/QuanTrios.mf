beginchar("y", 5.84u#, xh#, desc#);
  qt_line(.20u, xh, 2.92u, 0);
  qt_line(5.64u, xh, 2.92u, 0);
  qt_line(2.92u, 0, 1.46u, -desc);
endchar;

beginchar("z", 5.03u#, xh#, 0);
  qt_hbar(.04u, 4.98u, xh-halfsw);
  qt_line(4.98u, xh, .04u, 0);
  qt_hbar(.04u, 4.98u, halfsw);
endchar;

% ============================================================
% Figures: 0-9
% ============================================================

