  qt_curve_pen;
  draw (1.56u, -1.72u)
    .. controls (1.42u, -2.52u) and (.38u, -2.52u) .. (.18u, -1.68u);
  qt_dot(1.56u, xh + .98u);
endchar;

beginchar("k", 5.46u#, cap#, 0);
  qt_vstem(.79u, 0, cap);
  qt_line(.79u, 2.62u, 4.92u, xh);
  qt_line(.79u, 2.62u, 5.18u, 0);
endchar;

beginchar("l", 1.91u#, cap#, 0);
  qt_vstem(.96u, 0, cap);
endchar;

beginchar("m", 9.08u#, xh#, 0);
  qt_vstem(.79u + halfsw, 0, xh);
  qt_vstem(4.54u, 0, 3.08u);
  qt_vstem(8.35u - halfsw, 0, 3.08u);
  qt_curve_pen;
  draw (.79u + halfsw, xh-halfsw)
    .. controls (1.55u, xh+.02u) and (4.54u, xh-.06u) .. (4.54u, 3.08u);
  draw (4.54u, xh-halfsw)
    .. controls (5.30u, xh+.02u) and (8.35u - halfsw, xh-.06u) .. (8.35u - halfsw, 3.08u);
endchar;

beginchar("n", 5.74u#, xh#, 0);
  save lx, rx;
  lx := .79u + halfsw; rx := 5.02u - halfsw;
  qt_vstem(lx, 0, xh);
  qt_vstem(rx, 0, 3.04u);
  qt_curve_pen;
  draw (lx, xh-halfsw)
    .. controls (1.78u, xh+.02u) and (rx, xh-.06u)
    .. (rx, 3.04u);
endchar;

beginchar("o", 5.70u#, xh# + overshoot#, overshoot#);
