endchar;

beginchar("6", 5.58u#, digit# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (4.70u, 7.10u)
    .. controls (3.44u, 8.72u) and (.74u, 6.24u) .. (.82u, 3.20u)
