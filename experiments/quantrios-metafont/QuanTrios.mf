% QuanTrios.mf
% QT project / QuanTrios METAFONT prototype v7
%
% Purpose:
% - Build a Futura-informed monoline / centerline METAFONT.
% - Primary source is centerline geometry for animation and deformation.
% - Futura Medium is used only as measured reference for proportions.
% - No Futura outline data is stored or traced here.
%
% Revert point:
% backup/quantrios-metafont-before-rework

mode_setup;
font_identifier := "QuanTriosMono";
font_size 10pt#;

% Futura Medium reference normalized to cap = 8.
u# := 1pt#;
cap# := 8pt#;
xh# := 5.19pt#;
digit# := 8.13pt#;
sw# := .52pt#;
overshoot# := .15pt#;
desc# := 2.60pt#;

define_pixels(u, cap, xh, digit, sw, overshoot, desc);

font_x_height xh#;
font_quad 10u#;
font_normal_space 3u#;
font_normal_stretch 1.5u#;
font_normal_shrink 1u#;

numeric halfsw;
halfsw := sw / 2;

% ------------------------------------------------------------
% Centerline output primitives
% ------------------------------------------------------------

def qt_curve_pen =
  pickup pencircle scaled sw
enddef;

def qt_vstem(expr xx, ya, yb) =
  fill (xx-halfsw,ya)--(xx+halfsw,ya)--(xx+halfsw,yb)--(xx-halfsw,yb)--cycle
enddef;

def qt_hbar(expr xa, xb, yy) =
  fill (xa,yy-halfsw)--(xb,yy-halfsw)--(xb,yy+halfsw)--(xa,yy+halfsw)--cycle
enddef;

def qt_line(expr xa, ya, xb, yb) =
  pickup pensquare scaled sw rotated angle((xb-xa,yb-ya));
  draw (xa,ya)--(xb,yb)
enddef;

def qt_bowl(expr cx, cy, rx, ry) =
  qt_curve_pen;
  draw fullcircle xscaled (2rx) yscaled (2ry) shifted (cx, cy)
enddef;

def qt_dot(expr cx, cy) =
  fill fullcircle scaled (sw * 1.12) shifted (cx, cy)
enddef;

def qt_cap_bowl(expr cx, cy, rx, ry) =
  qt_bowl(cx, cy, rx, ry)
enddef;

def qt_lower_bowl(expr cx, cy, rx, ry) =
  qt_bowl(cx, cy, rx, ry)
enddef;

% Shared measured bowl centers/radii.
numeric cap_bowl_cx, cap_bowl_cy, cap_bowl_rx, cap_bowl_ry;
numeric lower_o_cx, lower_o_cy, lower_o_rx, lower_o_ry;
cap_bowl_cx := 4.03u;
cap_bowl_cy := 4.00u;
cap_bowl_rx := (6.94u - sw) / 2;
cap_bowl_ry := (8.31u - sw) / 2;
lower_o_cx := 2.85u;
lower_o_cy := .50xh;
lower_o_rx := (4.90u - sw) / 2;
lower_o_ry := (5.34u - sw) / 2;

% ============================================================
% Uppercase: A-Z
% ============================================================

beginchar("A", 7.86u#, cap# + overshoot#, 0);
  qt_line(.32u, 0, 3.93u, cap);
  qt_line(3.93u, cap, 7.54u, 0);
  qt_hbar(1.82u, 6.04u, 3.02u);
endchar;

beginchar("B", 6.27u#, cap#, 0);
  qt_vstem(.96u, 0, cap);
  qt_curve_pen;
  draw (.96u, cap) -- (3.55u, cap)
    .. controls (5.35u, cap) and (5.35u, 4.18u) .. (3.55u, 4.18u)
    -- (.96u, 4.18u);
  draw (.96u, 4.18u) -- (3.80u, 4.18u)
    .. controls (5.72u, 4.18u) and (5.72u, 0) .. (3.80u, 0)
    -- (.96u, 0);
endchar;

beginchar("C", 7.44u#, cap# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (6.55u, 6.74u)
    .. controls (5.72u, 8.15u) and (2.28u, 8.18u) .. (1.02u, 5.62u)
    .. controls (-.05u, 3.42u) and (1.08u, -.12u) .. (4.05u, -.12u)
    .. controls (5.35u, -.12u) and (6.10u, .42u) .. (6.55u, 1.22u);
endchar;

beginchar("D", 7.54u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_curve_pen;
  draw (.89u, cap) -- (3.70u, cap)
    .. controls (6.62u, cap) and (7.00u, 0) .. (3.70u, 0)
    -- (.89u, 0);
endchar;

beginchar("E", 4.81u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_hbar(.89u, 4.20u, cap-halfsw);
  qt_hbar(.89u, 3.72u, .50cap);
  qt_hbar(.89u, 4.20u, halfsw);
endchar;

beginchar("F", 4.55u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_hbar(.89u, 4.05u, cap-halfsw);
  qt_hbar(.89u, 3.60u, .50cap);
endchar;

beginchar("G", 8.05u#, cap# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (6.92u, 6.76u)
    .. controls (5.95u, 8.15u) and (2.25u, 8.15u) .. (1.02u, 5.55u)
    .. controls (-.03u, 3.34u) and (1.10u, -.12u) .. (4.18u, -.12u)
    .. controls (6.52u, -.12u) and (7.22u, 1.48u) .. (7.22u, 3.42u);
  qt_hbar(4.42u, 7.22u, 3.42u);
endchar;

beginchar("H", 7.31u#, cap#, 0);
  qt_vstem(.91u + halfsw, 0, cap);
  qt_vstem(6.40u - halfsw, 0, cap);
  qt_hbar(.91u + halfsw, 6.40u - halfsw, .50cap);
endchar;

beginchar("I", 2.13u#, cap#, 0);
  qt_vstem(1.06u, 0, cap);
endchar;

beginchar("J", 3.57u#, cap#, desc#);
  qt_vstem(2.60u, 1.02u, cap);
  qt_curve_pen;
  draw (2.60u, 1.02u)
    .. controls (2.60u, -.55u) and (.44u, -.62u) .. (.36u, 1.05u);
endchar;

beginchar("K", 6.55u#, cap#, 0);
  qt_vstem(.90u, 0, cap);
  qt_line(.90u, 3.52u, 5.86u, cap);
  qt_line(.90u, 3.52u, 6.18u, 0);
endchar;

beginchar("L", 4.19u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_hbar(.89u, 3.56u, halfsw);
endchar;

beginchar("M", 8.35u#, cap#, 0);
  qt_vstem(.91u, 0, cap);
  qt_vstem(7.44u, 0, cap);
  qt_line(.91u, cap, 4.18u, .84u);
  qt_line(4.18u, .84u, 7.44u, cap);
endchar;

beginchar("N", 7.35u#, cap#, 0);
  qt_vstem(.91u, 0, cap);
  qt_vstem(6.45u, 0, cap);
  qt_line(.91u, cap, 6.45u, 0);
endchar;

beginchar("O", 8.05u#, cap# + overshoot#, overshoot#);
  qt_bowl(cap_bowl_cx, cap_bowl_cy, cap_bowl_rx, cap_bowl_ry);
endchar;

beginchar("P", 5.56u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_curve_pen;
  draw (.89u, cap) -- (3.50u, cap)
    .. controls (5.12u, cap) and (5.12u, 3.92u) .. (3.50u, 3.92u)
    -- (.89u, 3.92u);
endchar;

beginchar("Q", 8.05u#, cap# + overshoot#, desc#);
  qt_bowl(cap_bowl_cx, cap_bowl_cy, cap_bowl_rx, cap_bowl_ry);
  qt_line(4.50u, 1.10u, 5.72u, -1.48u);
endchar;

beginchar("R", 6.73u#, cap#, 0);
  qt_vstem(.89u, 0, cap);
  qt_curve_pen;
  draw (.89u, cap) -- (3.55u, cap)
    .. controls (5.18u, cap) and (5.18u, 3.94u) .. (3.55u, 3.94u)
    -- (.89u, 3.94u);
  qt_line(2.88u, 3.94u, 6.15u, 0);
endchar;

beginchar("S", 5.91u#, cap# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (5.05u, 6.88u)
    .. controls (3.82u, 8.22u) and (1.22u, 7.78u) .. (.86u, 5.90u)
    .. controls (.50u, 4.05u) and (2.16u, 3.62u) .. (3.30u, 3.48u)
    .. controls (5.10u, 3.25u) and (5.36u, .78u) .. (3.25u, .12u)
    .. controls (2.15u, -.22u) and (.94u, .18u) .. (.48u, 1.10u);
endchar;

beginchar("T", 5.93u#, cap#, 0);
  qt_hbar(.04u, 5.88u, cap-halfsw);
  qt_vstem(2.96u, 0, cap);
endchar;

beginchar("U", 7.23u#, cap# + overshoot#, overshoot#);
  qt_vstem(.78u + halfsw, 1.30u, cap);
  qt_vstem(6.45u - halfsw, 1.30u, cap);
  qt_curve_pen;
  draw (.78u + halfsw, 1.30u)
    .. controls (.78u + halfsw, -.12u) and (6.45u - halfsw, -.12u)
    .. (6.45u - halfsw, 1.30u);
endchar;

beginchar("V", 7.86u#, cap#, 0);
  qt_line(.32u, cap, 3.93u, 0);
  qt_line(7.54u, cap, 3.93u, 0);
endchar;

beginchar("W", 11.28u#, cap#, 0);
  qt_line(.38u, cap, 2.92u, 0);
  qt_line(2.92u, 0, 5.64u, cap);
  qt_line(5.64u, cap, 8.36u, 0);
  qt_line(8.36u, 0, 10.90u, cap);
endchar;

beginchar("X", 7.19u#, cap#, 0);
  qt_line(.28u, 0, 6.90u, cap);
  qt_line(.28u, cap, 6.90u, 0);
endchar;

beginchar("Y", 7.86u#, cap#, 0);
  qt_line(.32u, cap, 3.93u, 3.72u);
  qt_line(7.54u, cap, 3.93u, 3.72u);
  qt_vstem(3.93u, 0, 3.72u);
endchar;

beginchar("Z", 6.47u#, cap#, 0);
  qt_hbar(.04u, 6.43u, cap-halfsw);
  qt_line(6.43u, cap, .04u, 0);
  qt_hbar(.04u, 6.43u, halfsw);
endchar;

% ============================================================
% Lowercase: a-z
% ============================================================

beginchar("a", 5.81u#, xh# + overshoot#, overshoot#);
  save acx, arx, astem;
  acx := .40u + 4.95u / 2;
  arx := (4.95u - sw) / 2;
  astem := .40u + 4.95u - halfsw;
  qt_bowl(acx, lower_o_cy, arx, lower_o_ry);
  qt_vstem(astem, 0, xh);
endchar;

beginchar("b", 5.94u#, cap# + overshoot#, overshoot#);
  qt_vstem(.79u + halfsw, -desc, cap);
  qt_bowl(3.12u, lower_o_cy, (4.66u - sw)/2, lower_o_ry);
endchar;

beginchar("c", 5.03u#, xh# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (4.58u, 4.34u)
    .. controls (3.82u, 5.18u) and (1.20u, 5.18u) .. (.58u, 3.64u)
    .. controls (.02u, 2.28u) and (.92u, -.10u) .. (2.80u, -.10u)
    .. controls (3.70u, -.10u) and (4.24u, .20u) .. (4.58u, .84u);
endchar;

beginchar("d", 5.94u#, cap# + overshoot#, overshoot#);
  qt_vstem(5.16u - halfsw, -desc, cap);
  qt_bowl(2.82u, lower_o_cy, (4.67u - sw)/2, lower_o_ry);
endchar;

beginchar("e", 5.68u#, xh# + overshoot#, overshoot#);
  qt_bowl(2.80u, lower_o_cy, (4.81u - sw)/2, lower_o_ry);
  qt_hbar(.82u, 4.70u, .50xh);
endchar;

beginchar("f", 3.67u#, cap#, 0);
  qt_vstem(1.78u, 0, cap);
  qt_hbar(.42u, 3.38u, xh);
  qt_curve_pen;
  draw (1.78u, cap) .. controls (1.78u, cap+.35u) and (2.78u, cap+.20u) .. (3.08u, cap-.26u);
endchar;

beginchar("g", 5.94u#, xh# + overshoot#, desc#);
  qt_bowl(2.82u, lower_o_cy, (4.67u - sw)/2, lower_o_ry);
  qt_vstem(5.16u - halfsw, -1.65u, xh);
  qt_curve_pen;
  draw (5.16u - halfsw, -1.65u)
    .. controls (4.62u, -2.54u) and (2.12u, -2.54u) .. (1.62u, -1.42u);
endchar;

beginchar("h", 5.74u#, cap#, 0);
  save lx, rx;
  lx := .79u + halfsw; rx := 5.02u - halfsw;
  qt_vstem(lx, 0, cap);
  qt_vstem(rx, 0, 3.04u);
  qt_curve_pen;
  draw (lx, xh-halfsw)
    .. controls (1.78u, xh+.02u) and (rx, xh-.06u)
    .. (rx, 3.04u);
endchar;

beginchar("i", 1.91u#, xh# + 1.55u#, 0);
  qt_vstem(.96u, 0, xh);
  qt_dot(.96u, xh + .98u);
endchar;

beginchar("j", 2.36u#, xh# + 1.55u#, desc#);
