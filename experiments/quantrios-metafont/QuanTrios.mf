endchar;

beginchar("p", 5.94u#, xh# + overshoot#, desc#);
  qt_vstem(.79u + halfsw, -desc, xh);
  qt_bowl(3.12u, lower_o_cy, (4.66u - sw)/2, lower_o_ry);
endchar;

beginchar("q", 5.94u#, xh# + overshoot#, desc#);
  qt_bowl(2.82u, lower_o_cy, (4.67u - sw)/2, lower_o_ry);
  qt_vstem(5.16u - halfsw, -desc, xh);
endchar;

beginchar("r", 3.52u#, xh#, 0);
  save lx, ex;
  lx := .79u + halfsw; ex := 3.34u - halfsw;
  qt_vstem(lx, 0, xh);
  qt_curve_pen;
  draw (lx, xh-halfsw)
    .. controls (1.32u, xh+.02u) and (2.42u, xh-.06u)
    .. (ex, 4.32u);
endchar;

beginchar("s", 3.85u#, xh# + overshoot#, overshoot#);
  qt_curve_pen;
  draw (3.20u, 4.55u)
    .. controls (2.62u, 5.10u) and (1.02u, 5.08u) .. (.70u, 4.12u)
    .. controls (.38u, 3.16u) and (1.08u, 2.72u) .. (1.92u, 2.57u)
